    "@aws-sdk/lib-dynamodb": "^3.490.0",
    "@middy/core": "^4.7.0",
    "@middy/error-logger": "^4.7.0",
    "@middy/http-error-handler": "^4.7.0",
    "@middy/http-json-body-parser": "^4.7.0",
    "@middy/input-output-logger": "^4.7.0",
